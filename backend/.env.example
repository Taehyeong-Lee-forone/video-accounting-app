# ===========================
# GPT-4V統合設定 (必須)
# ===========================
# OpenAI API Key (GPT-4 Vision用)
# https://platform.openai.com/api-keys で取得
OPENAI_API_KEY=your-openai-api-key-here

# Vision Provider (gpt4v固定)
VISION_PROVIDER=gpt4v

# ===========================
# 旧設定 (GPT-4V移行後は不要)
# ===========================
# AI_PROVIDER=openai  # 廃止
# GEMINI_API_KEY=xxx  # 廃止 - GPT-4Vに統合
# GOOGLE_APPLICATION_CREDENTIALS_JSON=xxx  # 廃止 - GPT-4Vに統合

# Email設定 (パスワードリセット用)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=forone.video2@gmail.com
SMTP_PASSWORD=ujqbdsagmerfbnvp
FROM_EMAIL=forone.video2@gmail.com

# Database設定
DATABASE_URL=postgresql://user:password@host:port/dbname

# その他の設定
RENDER=false
USE_SQLITE=false
DEMO_MODE=false